# Pick ONE LLM. Gemini is the default and the cheapest path.
GEMINI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here

# Runtime: gemini-flash (default) | claude-sonnet-4-6
BEGENIUX_RUNTIME=gemini-flash

# Optional model overrides
# BEGENIUX_GEMINI_MODEL=gemini-2.0-flash
# BEGENIUX_CLAUDE_MODEL=claude-sonnet-4-6

# Optional: change the langgraph dev port (default 8133)
# BEGENIUX_AGENT_PORT=8133
